# --- Secrets (obrigatório) ---
UI_USERNAME=admin
UI_PASSWORD=change-me-use-openssl-rand-hex-32
ADMIN_API_KEY=change-me-use-openssl-rand-hex-32

# Recomendado em VPS pública — SinkSeq envia no header X-Seq-ApiKey
INGEST_API_KEY=

# --- Imagens públicas (GHCR — publicadas pelo CI) ---
# CLEF_VIEWER_SERVER_IMAGE=ghcr.io/altamir/clef-viewer-server:latest
# CLEF_VIEWER_WEBAPP_IMAGE=ghcr.io/altamir/clef-viewer-webapp:latest

# --- Traefik (VPS com HTTPS) ---
CLEF_UI_HOST=clef.altamir.dev
CLEF_INGEST_HOST=clef-ingest.altamir.dev
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# Portas locais (127.0.0.1 — acesso público via Traefik)
CLEF_VIEWER_PORT_MAPPING=127.0.0.1:5341:5341
CLEF_VIEWER_UI_PORT_MAPPING=127.0.0.1:8080:80

# --- Hostinger / IP direto (sem Traefik) ---
# CLEF_UI_HOST=localhost
# CLEF_INGEST_HOST=localhost
# CLEF_VIEWER_PORT_MAPPING=5341:5341
# CLEF_VIEWER_UI_PORT_MAPPING=8080:80

# --- Opcional ---
# MAX_ROWS=100000
# QUERY_MAX_LIMIT=100000